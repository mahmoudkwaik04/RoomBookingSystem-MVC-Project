@model RoomBookingSystem.ViewModels.LoginViewModel

@{
    Layout = null;
    ViewData["Title"] = "Login";
}

<!DOCTYPE html>
<html lang="en" dir="ltr">
<head>
    <meta charset="utf-8" />
    <title>Login - RoomBooking</title>
    <meta name="viewport" content="width=device-width, initial-scale=1" />

    <link rel="stylesheet" href="~/css/site.css" />

    <style>
        :root {
            --brand-1: #1e3a8a; /* indigo-900 */
            --brand-2: #2563eb; /* blue-600 */
            --brand-3: #3b82f6; /* blue-500 */
            --text-1: #111827; /* gray-900 */
            --text-2: #6b7280; /* gray-500 */
            --border: #e5e7eb; /* gray-200 */
        }

        html, body { height: 100%; }

        body {
            margin: 0;
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
            background:
                radial-gradient(900px 500px at 80% -10%, rgba(255,255,255,.12), transparent 60%),
                linear-gradient(135deg, var(--brand-1) 0%, var(--brand-2) 50%, #1d4ed8 100%);
            background-size: 140% 140%;
            animation: gradientShift 18s ease infinite;
            display: grid;
            place-items: center;
        }

        @@keyframes gradientShift {
            0% { background-position: 0% 50%; }
            50% { background-position: 100% 50%; }
            100% { background-position: 0% 50%; }
        }

        .auth-wrap {
            width: min(94vw, 980px);
            display: grid;
            grid-template-columns: 1.1fr .9fr;
            gap: 0;
            background: rgba(255,255,255, .06);
            border-radius: 22px;
            box-shadow: 0 30px 90px rgba(0,0,0,.28);
            overflow: hidden;
            backdrop-filter: blur(6px);
        }
        @@media (max-width: 900px) {
            .auth-wrap { grid-template-columns: 1fr; width: min(94vw, 520px);}        
            .auth-side { display: none; }
            .auth-card { border-radius: 22px; }
        }

        /* Left side (branding) */
        .auth-side {
            position: relative;
            padding: 36px 36px 24px;
            color: #fff;
            background: linear-gradient(160deg, rgba(255,255,255,.12), rgba(255,255,255,.02));
            overflow: hidden;
        }
        .auth-side::after {
            content: "";
            position: absolute; inset: 0;
            background:
                url('data:image/svg+xml;utf8,<svg xmlns="http://www.w3.org/2000/svg" width="400" height="400" viewBox="0 0 400 400" fill="none"><g opacity="0.25"><circle cx="60" cy="80" r="3" fill="white"/><circle cx="180" cy="160" r="3" fill="white"/><circle cx="120" cy="260" r="3" fill="white"/><circle cx="240" cy="100" r="2" fill="white"/><circle cx="300" cy="220" r="2" fill="white"/></g></svg>') center/220px 220px repeat;
            opacity: .8;
            pointer-events: none;
            animation: patternDrift 30s linear infinite;
        }
        @@keyframes patternDrift {
            0% { transform: translate3d(0,0,0); }
            50% { transform: translate3d(-20px,10px,0); }
            100% { transform: translate3d(0,0,0); }
        }
        .orb { position: absolute; border-radius: 999px; filter: blur(20px); opacity: .35; }
        .orb.one { width: 160px; height: 160px; background: #60a5fa; top: 12%; left: 8%; animation: float 10s ease-in-out infinite; }
        .orb.two { width: 220px; height: 220px; background: #93c5fd; bottom: -30px; right: -30px; animation: float 14s ease-in-out -2s infinite; }
        @@keyframes float {
            0%,100% { transform: translateY(0) translateX(0); }
            50% { transform: translateY(-14px) translateX(8px); }
        }

        .brand { position: relative; z-index: 1; display: flex; align-items: center; gap: 10px; margin-bottom: 18px; }
        .brand img { height: 56px; width: auto; filter: drop-shadow(0 6px 18px rgba(0,0,0,.25)); }
        .brand span { font-weight: 800; letter-spacing: .3px; font-size: 1.25rem; }
        .side-title { position: relative; z-index: 1; font-size: 1.6rem; font-weight: 800; margin: 6px 0 8px; }
        .side-text { position: relative; z-index: 1; color: rgba(255,255,255,.9); line-height: 1.7; }

        /* Right side (form) */
        .auth-card {
            background: #fff;
            padding: 38px 32px 30px;
            animation: cardReveal .6s ease both;
        }
        @@keyframes cardReveal {
            from { opacity: 0; transform: translateY(12px); }
            to   { opacity: 1; transform: translateY(0); }
        }

        .auth-card .logo-center { text-align: center; margin-bottom: 12px; }
        .logo-badge {
            display: inline-flex;
            align-items: center; justify-content: center;
            background: #ffffff;
            padding: 12px 16px;
            border-radius: 16px;
            border: 1px solid #eef2f7;
            box-shadow: 0 8px 22px rgba(0,0,0,.08);
        }
        .logo-badge img { height: 72px; width: auto; display: block; }

        .auth-title { text-align: center; color: var(--text-1); font-weight: 800; font-size: 1.7rem; margin: 8px 0 2px; }
        .auth-subtitle { text-align: center; color: var(--text-2); margin-bottom: 22px; }

        .form-group { margin-bottom: 14px; }
        .form-input {
            width: 100%;
            padding: 12px 14px;
            border-radius: 12px;
            border: 1px solid var(--border);
            font-size: 14px;
            transition: box-shadow .2s, border-color .2s;
        }
        .form-input:focus {
            outline: none;
            border-color: var(--brand-2);
            box-shadow: 0 0 0 .25rem rgba(37,99,235,.15);
        }

        .btn-primary {
            width: 100%;
            background: linear-gradient(135deg, var(--brand-2), var(--brand-3));
            border: none; color: #fff; padding: 12px 16px;
            border-radius: 12px; font-size: 15px; font-weight: 800; letter-spacing: .2px;
            box-shadow: 0 12px 30px rgba(37,99,235,.28);
            cursor: pointer;
            transition: transform .15s ease, filter .15s ease;
        }
        .btn-primary:hover { filter: brightness(1.05); transform: translateY(-1px); }

        .text-danger { color: #dc2626; font-size: 13px; }
        .muted { color: #9ca3af; text-align: center; font-size: .9rem; margin-top: 14px; }
        .validation-summary-errors ul { margin: 0 0 10px 0; padding-inline-start: 18px; }
    </style>
</head>
<body>
    <div class="auth-wrap">
        <div class="auth-side">
            <div class="orb one"></div>
            <div class="orb two"></div>

                        <div class="side-title">Room Booking System</div>
            <div class="side-text">Manage room reservations with ease. Sign in to access your dashboard and keep everything organized.</div>
        </div>

        <div class="auth-card">
            <div class="logo-center">
                <div class="logo-badge">
                    <img src="~/images/logo.png" alt="RoomBooking Logo" />
                </div>
            </div>
            <div class="auth-title">Welcome Back</div>
            <div class="auth-subtitle">Sign in to your account</div>

            @using (Html.BeginForm("Login", "Account", FormMethod.Post, new { role = "form" }))
            {
                @Html.AntiForgeryToken()
                @Html.ValidationSummary(true, "", new { @class = "text-danger" })

                <div class="form-group">
                    @Html.TextBoxFor(m => m.Email, new { @class = "form-input", placeholder = "Email address" })
                    @Html.ValidationMessageFor(m => m.Email, "", new { @class = "text-danger" })
                </div>
                <div class="form-group">
                    @Html.PasswordFor(m => m.Password, new { @class = "form-input", placeholder = "Password" })
                    @Html.ValidationMessageFor(m => m.Password, "", new { @class = "text-danger" })
                </div>

                <button type="submit" class="btn-primary">Sign In</button>
            }

            <div class="muted">© @DateTime.Now.Year RoomBookingSystem</div>
        </div>
    </div>

    @await Html.PartialAsync("~/Views/Shared/_ValidationScriptsPartial.cshtml")
</body>
</html>