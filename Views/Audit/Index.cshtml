@model List<RoomBookingSystem.Models.AuditLog>

@{
    ViewData["Title"] = "Audit Logs";
}

<div class="page-header">
    <div>
        <h2>Audit Logs</h2>
        <p class="page-subtitle">System activity and important actions</p>
    </div>
</div>

<div class="card">
    @if (Model == null || !Model.Any())
    {
        <div class="empty-state">
            <h3>No logs available</h3>
            <p>Audit entries will appear here after system actions occur.</p>
        </div>
    }
    else
    {
        <table class="table">
            <thead>
                <tr>
                    <th>User ID</th>
                    <th>Action</th>
                    <th>Timestamp</th>
                    <th>Details</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var log in Model)
                {
                    <tr>
                        <td>@log.UserID</td>
                        <td>@log.Action</td>
                        <td>@log.Timestamp</td>
                        <td>@log.Details</td>
                    </tr>
                }
            </tbody>
        </table>
    }
</div>