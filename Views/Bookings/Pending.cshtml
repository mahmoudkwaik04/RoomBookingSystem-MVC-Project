@model List<RoomBookingSystem.Models.Booking>
@{
    ViewData["Title"] = "Pending Requests";
}

<div class="card">
    <h2>Pending Booking Requests</h2>

    <table class="table">
        <thead>
            <tr>
                <th>Employee</th>
                <th>Room</th>
                <th>Start</th>
                <th>End</th>
                <th>Status</th>
                <th>Actions</th>
            </tr>
        </thead>
        <tbody>
        @foreach (var booking in Model)
        {
            <tr>
                <td>@booking.User?.FullName</td>
                <td>@booking.Room?.RoomName</td>
                <td>@booking.StartTime</td>
                <td>@booking.EndTime</td>
                <td>@booking.Status</td>
                <td>
                    <a asp-action="Approve" asp-route-id="@booking.BookingID" class="btn">Approve</a>
                    <a asp-action="Reject" asp-route-id="@booking.BookingID" class="btn" style="background:#dc2626;">Reject</a>
                </td>
            </tr>
        }
        </tbody>
    </table>
</div>